# MongoDB connection.
# Local — connects directly to whatever single-node replica set is on the port
# (Docker's rs0, or an existing local mongod). Change streams still work.
MONGODB_URI=mongodb://127.0.0.1:27017/?directConnection=true
# Hosted (MongoDB Atlas free tier M0 — already a replica set):
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority

MONGO_DB=pulse
PORT=4000
